# ===========================================
# Variables de Entorno - Sistema de Control de Inventario
# ===========================================
# Copia este archivo a .env y ajusta los valores
# Los valores aquí son los defaults

# ---------- ENTORNO ----------
ENV=dev  # dev, staging, prod

# ---------- APP ----------
APP_NAME=inventory_system
APP_VERSION=1.0.0

# ---------- DATABASE ----------
# Ruta relativa o absoluta de la base de datos
DB_PATH=data/inventory.db

# ---------- LOGGING ----------
# Nivel: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Ruta del archivo de log
LOG_FILE=logs/app.log

# ---------- SECURITY ----------
# Clave secreta para cryptographic (genera una aleatoria para producción)
# SECRET_KEY=tu-clave-secreta-aqui

# ---------- UI ----------
# Tema: light, dark, system
UI_THEME=system
# Idioma: es, en
UI_LANGUAGE=es